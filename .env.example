XGR_RPC_URL=https://rpc.xgr.network
XGR_EXPLORER_API_URL=https://explorer.xgr.network/api
MCP_SERVER_NAME=xgr-mcp-gateway
MCP_READONLY=true
MCP_HTTP_PORT=3100

PGRO_HOST=127.0.0.1
PGRO_PORT=5432
PGRO_USER=xgr_reader
PGRO_PASSWORD=
PGRO_DB=xgrscan
PGRO_POOL_MAX=4
PGRO_STATEMENT_TIMEOUT_MS=5000

MCP_OPERATION_STORE_DIR=./data/operations
MCP_OPERATION_PUBLIC_BASE_URL=https://mcp.xgr.network
MCP_PUBLIC_BASE_URL=https://mcp.xgr.network
MCP_OPERATION_DEFAULT_TTL_SECONDS=3600
MCP_OPERATION_MAX_TTL_SECONDS=86400

# Optional advanced override. Defaults to ${MCP_OPERATION_STORE_DIR}/bundle-deploy.
# MCP_BUNDLE_DEPLOY_STORE_DIR=/var/lib/xgr-mcp/operations/bundle-deploy
MCP_XDALA_BUNDLE_DEPLOY_BASE_URL=https://xdala.xgr.network/api/bundle-deploy
MCP_BUNDLE_DEPLOY_DEFAULT_TTL_SECONDS=3600
MCP_BUNDLE_DEPLOY_MAX_TTL_SECONDS=86400
